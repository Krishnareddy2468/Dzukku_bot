# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token

# ── Gemini AI (get from https://aistudio.google.com/app/apikey) ──
GEMINI_API_KEY=your_gemini_api_key
# Optional overrides (defaults: gemini-2.5-flash / gemini-flash-latest)
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-flash-latest

# ── Google Sheets sync ────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id
# Either set this env var with the full JSON string, or put credentials.json next to this file
GOOGLE_CREDENTIALS=

# ── PostgreSQL (vNext) ────────────────────────────────────────
DATABASE_URL=YOUR_DATABASE_URL_HERE
DATABASE_URL_SYNC=YOUR_DATABASE_URL_SYNC_HERE
DB_ECHO=false
DEFAULT_RESTAURANT_ID=1

# ── Object storage (vNext) ────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_BASE_URL=

# ── FastAPI server ────────────────────────────────────────────
PORT=8000

# ── External Ordering Platforms ───────────────────────────────
# Public Zomato / Swiggy listing URLs for Dzukku Restaurant.
# Shown to users who pick Zomato or Swiggy on the platform-selection prompt
# WHEN MCP_ENABLED=false. When MCP_ENABLED=true, those buttons route into
# the LangGraph MCP agent instead.
ZOMATO_URL=https://www.zomato.com/hyderabad/dzukku-restaurant
SWIGGY_URL=https://www.swiggy.com/restaurants/dzukku-restaurant

# ── MCP (Model Context Protocol) — Zomato / Swiggy live ordering ───
# Two deployment patterns:
#
# 1) CLOUD (recommended default): MCP_ENABLED=false
#    Telegram users who pick Zomato or Swiggy get a redirect link to the
#    app and place their order on their own account. No vendor whitelist
#    required, no per-user OAuth, no shared-token risk. Just works.
#
# 2) LOCAL DEMO / SINGLE-TENANT: MCP_ENABLED=true
#    The bot uses LangGraph + mcp-remote to actually order on your Zomato
#    /Swiggy account (every Telegram user's order goes to YOU). Setup:
#      a. On the host that will run the bot, run ONCE per server:
#           npx -y mcp-remote https://mcp-server.zomato.com/mcp
#           npx -y mcp-remote https://mcp.swiggy.com/food
#         A browser opens; log in. Tokens cached at ~/.mcp-auth/.
#      b. Set MCP_ENABLED=true.
#
#    For Docker / cloud demo deployments, run the export script to
#    package the cache for upload as a secret:
#         ./scripts/export_mcp_auth.sh
#    Then mount the extracted dir at MCP_AUTH_DIR (default /run/mcp-auth
#    in our docker-compose mcp profile).
MCP_ENABLED=false
NPX_BIN=npx
# Override only when running in Docker / cloud where ~/.mcp-auth isn't
# the right location. docker-compose mcp profile sets this to /run/mcp-auth.
MCP_AUTH_DIR=

# Optional: when running with docker compose --profile mcp, override the
# host source directory for the read-only mount (defaults to ~/.mcp-auth).
# MCP_AUTH_HOST_DIR=/path/to/exported/mcp-auth

# Per-server toggles (food on by default; instamart/dineout off)
MCP_ZOMATO_ENABLED=true
MCP_SWIGGY_FOOD_ENABLED=true
MCP_SWIGGY_INSTAMART_ENABLED=false
MCP_SWIGGY_DINEOUT_ENABLED=false

# Timeouts / cooldowns
MCP_TOOL_TIMEOUT_S=45
MCP_RECONNECT_COOLDOWN_S=30

# MCP endpoints (only override if Zomato/Swiggy moves them)
MCP_ZOMATO_URL=https://mcp-server.zomato.com/mcp
MCP_SWIGGY_FOOD_URL=https://mcp.swiggy.com/food
MCP_SWIGGY_INSTAMART_URL=https://mcp.swiggy.com/im
MCP_SWIGGY_DINEOUT_URL=https://mcp.swiggy.com/dineout
